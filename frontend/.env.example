# =============================================================================
# SecureData Web — Frontend Environment Variables
# =============================================================================
# Copy this file to frontend/.env and fill in your values.
# NEVER commit frontend/.env to version control.

# ---------------------------------------------------------------------------
# API
# ---------------------------------------------------------------------------

# URL of the backend API (no trailing slash)
# Development:
VITE_API_URL=http://localhost:8000

# Production (update to match your deployed backend URL):
# VITE_API_URL=https://api.yourdomain.com
